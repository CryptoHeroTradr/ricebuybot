# RiceBuybot — copy to .env and fill in. PLACEHOLDERS ONLY: never commit a real key.
# Boot validates every var below and reports ALL problems at once.

# --- Telegram ---
# From @BotFather. Format: <id>:<secret>
TELEGRAM_BOT_TOKEN=123456789:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# --- Solana / Helius ---
# The ORIGINAL key was published and is burned. Use a freshly rotated one, and never
# commit it. The WS/RPC URLs embed the key in the query string, which is why every
# log line that carries a URL goes through scrubUrl() first.
HELIUS_API_KEY=00000000-0000-0000-0000-000000000000
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=00000000-0000-0000-0000-000000000000
HELIUS_WS_URL=wss://atlas-mainnet.helius-rpc.com/?api-key=00000000-0000-0000-0000-000000000000

# --- Ingestion ---
# ws      = Helius Enhanced WebSocket transactionSubscribe (default; Geyser-backed)
# webhook = Helius POSTs to us at /helius/webhook on HTTP_PORT (fallback)
INGEST_MODE=ws
# Required when INGEST_MODE=webhook. Compared in constant time against the
# Authorization header. Min 16 chars. The endpoint is public — treat as a password.
# NOTE: the HTTP server binds to 127.0.0.1, so webhook mode needs a reverse proxy
# in front of it. Do not expose the port directly.
WEBHOOK_SECRET=

# Mint used when a group has not configured its own. Flagship is $RICE.
DEFAULT_MINT=2wQq3MrFFHPQnapMt1wnZ2vGkVZDv5ENDCrdLCqFpump

# --- Storage ---
DB_PATH=./data/ricebuybot.db

# --- Ops ---
# 3012 is free on the VPS (3011 is taken by a Next app bound *:3011). Bound to 127.0.0.1. GET /health -> {"ok":true,"uptime":n}
HTTP_PORT=3012
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- Media pool ---
# The bot OWNS this tree and is its sole writer (invariant 4). No sync job, no meme bot.
# On the VPS it is ricebuybot:www-data, dirs 2750 / files 0640 — nginx reads, deploy cannot.
# Layout: <MEDIA_ROOT>/<mint>/{regular,big,whale,massive}/ + <mint>/_archive/ + _incoming/<mint>/
# Curated with scripts/tier.ts; manifest.json is generated, never hand-edited.
MEDIA_ROOT=/srv/media
# local = read the folder directly. http = fetch MEDIA_MANIFEST_URL (then required).
MEDIA_SOURCE=local
MEDIA_MANIFEST_URL=
# Private chat the bot uploads each meme into ONCE, to mint a reusable file_id.
# Telegram file_ids are bot-specific and non-portable, so RiceBuybot must do this itself.
# Required unless DRY_RUN=true.
MEDIA_VAULT_CHAT_ID=-1000000000000

# --- Pricing ---
# What a stablecoin quote (USDC/USDT) is worth. Configurable on purpose: if USDC
# depegs, that is real, and hiding it behind a hardcoded 1.00 misprices every buy.
STABLE_USD=1.0
# Value a whale's holdings on their post-trade balance (default) or pre-trade.
WHALE_BASIS=post

# --- Behaviour ---
# Seed historical cost basis from Helius before live ingestion starts.
BACKFILL_POSITIONS=true
# true = render posts to stdout and send nothing.
DRY_RUN=false
