{
  "name": "ricebuybot",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted multi-tenant Telegram buy bot for Solana SPL tokens",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-migrations.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node --env-file-if-exists=.env dist/src/index.js",
    "dev": "node --env-file-if-exists=.env --watch dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "media:manifest": "node scripts/build-manifest.ts",
    "media:tier": "node scripts/tier.ts",
    "verify:live": "DRY_RUN=true timeout 60 node --env-file-if-exists=.env dist/src/index.js",
    "cards:dry": "node dist/scripts/dry-run-cards.js",
    "cards:fixtures": "pnpm build && node dist/scripts/dry-run-cards.js --fixtures",
    "audit:network": "node scripts/audit-network.mjs",
    "deploy:bot": "bash scripts/setup-bot.sh",
    "deploy:verify": "bash scripts/verify-deploy.sh",
    "backup": "bash scripts/backup-db.sh"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "grammy": "^1.44.0",
    "pino": "^9.6.0",
    "ws": "^8.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
